<T3DataStructure>
    <sheets>
        <sDEF>
            <ROOT>
                <sheetTitle>Settings</sheetTitle>
                <type>array</type>
                <el>
                    <settings.limit>
                        <label>Max records to display (0 for all)</label>
                        <config>
                            <type>input</type>
                            <size>5</size>
                            <eval>int</eval>
                            <default>10</default>
                        </config>
                    </settings.limit>

                    <settings.sortOrder>
                        <label>Sort Direction</label>
                        <config>
                            <type>select</type>
                            <renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0">
                                    <numIndex index="0">Ascending</numIndex>
                                    <numIndex index="1">asc</numIndex>
                                </numIndex>
                                <numIndex index="1">
                                    <numIndex index="0">Descending</numIndex>
                                    <numIndex index="1">desc</numIndex>
                                </numIndex>
                            </items>
                            <default>asc</default>
                        </config>
                    </settings.sortOrder>

                    <settings.storagePid>
                        <label>Select Storage Page</label>
                        <config>
                            <type>group</type>
                            <allowed>pages</allowed>
                            <size>1</size>
                            <maxitems>1</maxitems>
                            <minitems>0</minitems>
                        </config>
                    </settings.storagePid>

                </el>
            </ROOT>
        </sDEF>
    </sheets>
</T3DataStructure>